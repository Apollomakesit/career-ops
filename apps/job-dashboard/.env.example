DATABASE_URL="postgresql://user:password@host:5432/railway"
DASHBOARD_TOKEN="replace-with-a-long-random-token"
PORT=3000

# Local runners only
DASHBOARD_URL="https://your-dashboard.up.railway.app"
CAREER_OPS_BROWSER_PROFILE=".career-ops-browser"
PORTAL_DISCOVERY_PORTALS="ejobs,bestjobs,hipo,linkedin"
PORTAL_DISCOVERY_KEYWORDS_PER_PORTAL=6
PORTAL_DISCOVERY_MAX_JOBS=80

# Local AI via CLIProxyAPI. This uses your logged-in OpenAI/Codex or Anthropic/Claude account.
# Railway cannot reach localhost, so run npm run runner:control locally for account-backed AI drafts.
AI_PROVIDER="openai"
AI_BASE_URL="http://127.0.0.1:8317/api/provider/openai/v1"
AI_MODEL="gpt-5.2"
AI_PROXY_API_KEY=""
AI_FIT_LIMIT=40
AI_DRAFT_MIN_FIT=60
AI_DRAFT_LIMIT=20

# Optional hosted fallback if you still want Railway to generate drafts directly.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.2"
